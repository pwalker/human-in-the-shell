{
  "name": "@peterw-xyz/human-in-the-shell",
  "version": "0.0.1",
  "description": "A command line coding agent that keeps the human writing code.",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "pi"
  ],
  "license": "MIT",
  "author": "Peter Walker",
  "repository": {
    "type": "git",
    "url": "https://github.com/pwalker/human-in-the-shell"
  },
  "bin": {
    "hits": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "verify": "pnpm run fmt:check && pnpm run lint && pnpm run test && pnpm run check-types",
    "release": "changeset publish"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-tui": "^0.75.4",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.10.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.1",
      "onFail": "download"
    }
  }
}
